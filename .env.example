# Credenciais Azure — copie este arquivo para .env e preencha os valores
# cp .env.example .env

# ── Azure OpenAI (chave principal — usada por todos os modulos) ───────────────
AZURE_OPENAI_API_KEY=sua-chave-de-api-aqui
AZURE_OPENAI_ENDPOINT=https://seu-recurso.cognitiveservices.azure.com

# ── Transcricao (pipeline + transcribe) ──────────────────────────────────────
# Azure AI Speech usa as variaveis AZURE_OPENAI_* acima como fallback
# AZURE_SPEECH_KEY=chave-especifica-speech          # opcional
# AZURE_SPEECH_ENDPOINT=https://speech.azure.com    # opcional
# AZURE_SPEECH_LANGUAGE=pt-BR                       # padrao: pt-BR
# AZURE_SPEECH_MAX_SPEAKERS=10                      # padrao: 10

# ── Summarizer (identifica falantes pelo VTT + gera resumo via LLM) ──────────
# Usa as mesmas AZURE_OPENAI_* acima, so precisa configurar o deployment:
AZURE_OPENAI_DEPLOYMENT=gpt-5.4-mini
# AZURE_OPENAI_API_VERSION=2025-01-01-preview       # padrao: 2025-01-01-preview

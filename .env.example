# Credenciais Azure AI Speech — copie este arquivo para .env e preencha os valores
# cp .env.example .env

# ── Azure AI Speech (transcrição com diarização) ──────────────────────────────
# Se omitidos, o sistema usa as variáveis AZURE_OPENAI_* como fallback
# AZURE_SPEECH_KEY=sua-chave-de-api-aqui
# AZURE_SPEECH_ENDPOINT=https://seu-recurso.cognitiveservices.azure.com

# Opcionais
# AZURE_SPEECH_LANGUAGE=pt-BR     # idioma para transcrição (padrão: pt-BR)
# AZURE_SPEECH_MAX_SPEAKERS=10    # número máximo de falantes (padrão: 10)

# ── Azure OpenAI (usado como fallback para Speech, se não definido acima) ──────
AZURE_OPENAI_API_KEY=sua-chave-de-api-aqui
AZURE_OPENAI_ENDPOINT=https://seu-recurso.cognitiveservices.azure.com

# Não usado pela transcrição, mantido para outros módulos
AZURE_OPENAI_DEPLOYMENT_STT=gpt-4o-transcribe-diarize
# AZURE_OPENAI_API_VERSION=2025-04-01-preview
